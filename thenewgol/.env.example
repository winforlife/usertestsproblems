# Copier ce fichier en .env.local et renseigner les valeurs réelles.
# .env.local est ignoré par git.
# Reproduire toutes ces variables dans le dashboard Vercel avant déploiement.

# ── Resend — email transactionnel ─────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@thenewgol.com
EMAIL_CHRISTOPHE=christophe@thenewgol.com

# ── Airtable — stockage des réponses (Phase 1) ────────────────────────────────
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.xxx
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Reponses

# ── PostHog — analytics ────────────────────────────────────────────────────────
POSTHOG_API_KEY=phc_xxxxxxxxxxxx
POSTHOG_HOST=https://eu.posthog.com

# ── URLs ──────────────────────────────────────────────────────────────────────
URL_ARTICLE=https://thenewgol.com/article
